# ============================================================================
# WiCyS SOC Workshop -- environment example
# Copy to .env (which is gitignored) and fill in per-deployment values.
# ============================================================================

# Required in any non-workshop deployment. 32+ random chars recommended.
HMAC_SECRET=change-me-to-a-long-random-string

# API access key for SOC service endpoints. Required for process/log/sync APIs.
SOC_API_KEY=put-a-long-random-string-here

# Optional JWT bearer auth (HS256) + roles.
# If set, services accept Authorization: Bearer <jwt>. Keep SOC_API_KEY for
# internal service-to-service calls and workshop simplicity.
# JWT payload should include: {"sub":"user", "roles":["viewer"|"analyst"|"admin"], "exp":...}
SOC_JWT_SECRET=
SOC_JWT_ISSUER=
SOC_JWT_AUDIENCE=

# Optional OIDC (JWKS) validation.
# If SOC_OIDC_JWKS_URL is set, services validate Authorization: Bearer <jwt>
# using the JWKS keys and expected issuer/audience. Roles are read from `roles`
# (array/string) or `role` claim.
SOC_OIDC_JWKS_URL=

# JWT claim name used as SOC tenant for ingest/search isolation (when enabled).
SOC_JWT_TENANT_CLAIM=tenant

# ============================================================================
# Multi-tenant OpenSearch (collector)
# ============================================================================
# Default tenant tag on events when none is supplied (or for API-key flows).
SOC_DEFAULT_TENANT=default
# When 1, search/ingest/facets/entities are scoped by tenant; JWT users are
# pinned to their token tenant; API-key callers may pass ?tenant= as admin.
SOC_TENANT_ISOLATION=0
# Tenant filter applied by the correlation scheduler (internal searches).
CORRELATION_SOC_TENANT=

# ============================================================================
# Console OIDC (Vite build-time; docker-compose build args for `console`)
# ============================================================================
VITE_OIDC_ISSUER=
VITE_OIDC_CLIENT_ID=
# Optional; default is {public_origin}/auth/callback
VITE_OIDC_REDIRECT_URI=
VITE_OIDC_SCOPES=openid profile email

# ============================================================================
# Service wiring (URLs, paths)
# Override only if you are not using the default docker-compose service names.
# ============================================================================

# Core service URLs
COLLECTOR_URL=http://collector:8001
ORCHESTRATOR_URL=http://orchestrator:8021
DETECTOR_URL=http://detector:8000
POLICY_URL=http://policy_engine:8020
AUDIT_URL=http://audit:8022
OSINT_URL=http://osint:8028
LLM_ASSISTANT_URL=http://llm_assistant:8024

# Simulator → orchestrator: each event runs the full pipeline (LLM/OSINT can be slow).
# Increase if you see 504/timeout in scenario results (default 180s in docker-compose).
SIMULATOR_ORCHESTRATOR_TIMEOUT_SECONDS=180

# Integrations / OSINT scope allowlists (mounted inside containers)
SCOPES_PATH=/app/scopes.yaml
OSINT_SCOPES_PATH=/app/scopes.yaml

# Integrations state directory (cursor checkpoints, last-seen markers, etc.)
INTEGRATION_STATE_DIR=/app/integration_state

# LLM teacher shadow output log (lives on the audit/ledger volume)
LLM_SHADOW_LOG=/app/ledger/teacher_shadow.jsonl

# Audit ledger integrity and lifecycle controls.
AUDIT_SIGNING_KEY=change-me-to-a-long-random-signing-key
AUDIT_RETENTION_DAYS=90
# Case first-response SLA targets (hours from case create; used to set sla_response_due_at)
CASE_SLA_RESPONSE_HOURS_CRITICAL=4
CASE_SLA_RESPONSE_HOURS_HIGH=8
CASE_SLA_RESPONSE_HOURS_MEDIUM=24
CASE_SLA_RESPONSE_HOURS_LOW=72

# --- Student LLM (default: local Ollama) -----------------------------------
STUDENT_PROVIDER=ollama
STUDENT_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# --- Teacher LLM (disabled by default) -------------------------------------
# Set TEACHER_PROVIDER to one of: none, ollama, openai, anthropic
TEACHER_PROVIDER=none
TEACHER_MODEL=

# For OpenAI / Groq / OpenRouter / any OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# For Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# --- Routing ---------------------------------------------------------------
# student_only | teacher_only | teacher_shadow | teacher_then_student_refine
LLM_DEFAULT_MODE=student_only
LLM_HUMAN_REVIEW_MODE=teacher_shadow

# ============================================================================
# Detector toggles (optional)
# ============================================================================

# Enable/disable ML scoring layers in the detector service.
USE_ML=0
USE_FEDERATED=0

# ============================================================================
# LMS integrations (Phase 2)
# Leave any block blank to disable that provider.
# ============================================================================

# --- Canvas ---
# Example: https://canvas.instructure.com  (no trailing slash)
CANVAS_BASE_URL=
CANVAS_API_TOKEN=
# Comma-separated list of context codes for /announcements, e.g.
# "course_1234,course_5678". Required to pull announcements.
CANVAS_ANNOUNCEMENT_CONTEXTS=
CANVAS_INCLUDE_CONVERSATIONS=1
CANVAS_INCLUDE_ANNOUNCEMENTS=1

# --- Blackboard Learn ---
BLACKBOARD_BASE_URL=
BLACKBOARD_APP_KEY=
BLACKBOARD_APP_SECRET=

# --- Moodle ---
MOODLE_BASE_URL=
MOODLE_WSTOKEN=
MOODLE_USER_ID=0
MOODLE_FORUM_ID=

# --- D2L Brightspace ---
BRIGHTSPACE_BASE_URL=
BRIGHTSPACE_CLIENT_ID=
BRIGHTSPACE_CLIENT_SECRET=
BRIGHTSPACE_REFRESH_TOKEN=
BRIGHTSPACE_API_VERSION=1.26
BRIGHTSPACE_ORG_UNIT_ID=
BRIGHTSPACE_SCOPE=core:*:*

# ============================================================================
# Network / identity connectors (Phase 2b - opt-in)
# These run inside the `integrations` service and forward anonymized summaries
# to the collector via /ingest.
# ============================================================================

# --- Cisco Meraki (Dashboard API) ---
MERAKI_BASE_URL=https://api.meraki.com
MERAKI_API_KEY=
MERAKI_ORG_ID=
# Optional filters (comma-separated)
MERAKI_EVENT_TYPES=
MERAKI_PRODUCT_TYPES=
# When there is no cursor yet, limit initial pull window.
MERAKI_LOOKBACK_SECONDS=3600

# --- Cisco Duo (Admin API) ---
# Example: https://api-xxxxxxxx.duosecurity.com
DUO_BASE_URL=
DUO_IKEY=
DUO_SKEY=
DUO_INCLUDE_ADMIN_LOGS=0
# Optional: epoch seconds lower bound for logs.
DUO_MINTIME_EPOCH=0

# --- Cisco Umbrella (Reporting API) ---
UMBRELLA_BASE_URL=https://reports.api.umbrella.com
UMBRELLA_API_TOKEN=
# activity | security-activity
UMBRELLA_REPORT=security-activity

# --- Cisco ISE (monitoring endpoint) ---
ISE_BASE_URL=
ISE_USERNAME=
ISE_PASSWORD=

# --- Cisco Firepower FMC (audit records) ---
FMC_BASE_URL=
FMC_USERNAME=
FMC_PASSWORD=
FMC_DOMAIN_UUID=
FMC_TLS_VERIFY=1

# --- RESTCONF (generic) ---
RESTCONF_BASE_URL=
RESTCONF_BEARER_TOKEN=
# Must not contain "/" (scopes.yaml enforces a single-segment model by default)
RESTCONF_MODEL=ietf-interfaces:interfaces

# --- Device polling allowlist (SNMP/NETCONF/SSH) ---
# Comma-separated hostnames/IPs permitted for device polling. If set, any target
# not listed here is skipped.
DEVICE_ALLOWLIST=

# SNMP polling (targets host[:port])
SNMP_TARGETS=
SNMP_COMMUNITY=public
# Comma-separated OIDs. Default is sysUpTime.0
SNMP_OIDS=1.3.6.1.2.1.1.3.0

# NETCONF polling (targets host)
NETCONF_TARGETS=
NETCONF_USERNAME=
NETCONF_PASSWORD=
NETCONF_PORT=830
NETCONF_HOSTKEY_VERIFY=0

# SSH polling (targets host[:port])
SSH_TARGETS=
SSH_USERNAME=
SSH_PASSWORD=
SSH_PRIVATE_KEY=
# Comma-separated commands (keep read-only, non-invasive)
SSH_COMMANDS=show version

# ============================================================================
# Realtime traffic + anomaly detection (Phase 3)
# The traffic_ingestor service consumes normalized flows and emits anomalies
# back to /ingest. All detectors are off-by-default in emission until the
# warmup period has elapsed.
# ============================================================================

# Windowing
TRAFFIC_WINDOW_SECONDS=60
TRAFFIC_MAX_WINDOWS=240

# Privacy: subnets are bucketed to these prefix lengths before HMAC.
TRAFFIC_IPV4_PREFIX=24
TRAFFIC_IPV6_PREFIX=64
# Minimum number of peer groups (distinct src-subnet/service/proto cells)
# that must be active in a window before any anomaly is emitted.
TRAFFIC_K_ANON_MIN=5

# Detection
TRAFFIC_WARMUP_WINDOWS=15
TRAFFIC_EWMA_ALPHA=0.2
TRAFFIC_EWMA_Z=3.0
TRAFFIC_RATE_BURST_MULT=5.0
TRAFFIC_ISOFOREST_REFIT_EVERY=30
TRAFFIC_ISOFOREST_CONTAMINATION=0.05
TRAFFIC_ENABLE_EWMA=1
TRAFFIC_ENABLE_RATE_BURST=1
TRAFFIC_ENABLE_ISOFOREST=1

# Emission
TRAFFIC_EMIT_TO_COLLECTOR=1
TRAFFIC_SEVERITY_HIGH_Z=5.0
TRAFFIC_SEVERITY_MEDIUM_Z=3.0

# Workshop mode: auto-start the synthetic traffic generator on boot.
# Leave at 0 for real deployments; use POST /synthetic/start for on-demand.
TRAFFIC_SYNTHETIC_ENABLED=0

# ============================================================================
# OSINT enrichment (Phase 4)
# Event indicators (URL, domain, IP, file hash) are checked against the
# providers below. Providers that need an API key stay disabled until a
# key is present; free providers (URLhaus, OpenPhish, Phishtank,
# local MITRE) are enabled by default.
# ============================================================================

# Orchestrator control of enrichment
ENABLE_OSINT_ENRICHMENT=1
OSINT_TIMEOUT_SECONDS=30
# Events at or above this rule-based score trigger enrichment for
# non-email sources. email_gateway events are always enriched.
OSINT_MIN_RULE_SCORE=0.40

# Cache (clean results held 24h by default, hits 1h)
OSINT_CACHE_TTL_CLEAN=86400
OSINT_CACHE_TTL_HIT=3600
OSINT_CACHE_MAX_ENTRIES=5000

# Per-event indicator caps (privacy / cost control)
OSINT_MAX_URLS=5
OSINT_MAX_DOMAINS=5
OSINT_MAX_IPS=5
OSINT_MAX_HASHES=5

# Per-call + per-enrichment time budgets
OSINT_PER_PROVIDER_TIMEOUT=6
OSINT_PER_ENRICHMENT_DEADLINE=25

# Reject private / loopback / reserved IPs before they hit any provider.
OSINT_REJECT_PRIVATE_IPS=1

# --- VirusTotal -----------------------------------------------------------
VT_API_KEY=
OSINT_VT_RPM=4

# --- URLhaus (no key required) --------------------------------------------
OSINT_URLHAUS_RPM=60

# --- AbuseIPDB ------------------------------------------------------------
ABUSEIPDB_API_KEY=
OSINT_ABUSEIPDB_RPM=30

# --- AlienVault OTX -------------------------------------------------------
OTX_API_KEY=
OSINT_OTX_RPM=60

# --- Phishtank (app_key optional) -----------------------------------------
PHISHTANK_API_KEY=
PHISHTANK_APP_KEY=
OSINT_PHISHTANK_RPM=30

# --- OpenPhish (no key, feed pull) ----------------------------------------
OSINT_OPENPHISH_RPM=1

# Optional per-provider enable overrides (providers may still require keys)
# OSINT_VIRUSTOTAL_ENABLED=0
# OSINT_URLHAUS_ENABLED=1
# OSINT_ABUSEIPDB_ENABLED=0
# OSINT_OTX_ENABLED=0
# OSINT_PHISHTANK_ENABLED=1
# OSINT_OPENPHISH_ENABLED=1

# ============================================================================
# SIEM egress (optional; best-effort; disabled by default)
# These emit *anonymized* records from the collector to external platforms.
# ============================================================================

# --- Durable spool / queue (recommended if SIEM egress is enabled) ---
SIEM_SPOOL_ENABLED=0
# This directory lives inside the collector container. Default is under the
# mounted ./data volume so it persists across restarts.
SIEM_SPOOL_DIR=/app/data/siem_spool
SIEM_SPOOL_MAX_BYTES=209715200
SIEM_SPOOL_MAX_FILES=1000
SIEM_SPOOL_FLUSH_INTERVAL=5
SIEM_SPOOL_BATCH_SIZE=200
SIEM_SPOOL_MAX_ATTEMPTS=50

# --- Splunk HEC ---
SIEM_SPLUNK_HEC_ENABLED=0
SIEM_SPLUNK_HEC_URL=
SIEM_SPLUNK_HEC_TOKEN=
SIEM_SPLUNK_HEC_INDEX=
SIEM_SPLUNK_HEC_SOURCETYPE=agentic_soc
SIEM_SPLUNK_HEC_TIMEOUT=10
SIEM_SPLUNK_HEC_RETRIES=3
SIEM_SPLUNK_HEC_TLS_VERIFY=1
SIEM_SPLUNK_HEC_CA_BUNDLE=

# --- Elastic / OpenSearch (Bulk API) ---
SIEM_ELASTIC_ENABLED=0
SIEM_ELASTIC_URL=
SIEM_ELASTIC_API_KEY=
SIEM_ELASTIC_USERNAME=
SIEM_ELASTIC_PASSWORD=
SIEM_ELASTIC_INDEX=agentic-soc-events
SIEM_ELASTIC_BULK_PATH=/_bulk
SIEM_ELASTIC_TIMEOUT=10
SIEM_ELASTIC_RETRIES=3
SIEM_ELASTIC_TLS_VERIFY=1
SIEM_ELASTIC_CA_BUNDLE=

# --- Microsoft Sentinel (Log Analytics Data Collector API) ---
SIEM_SENTINEL_ENABLED=0
SIEM_SENTINEL_WORKSPACE_ID=
SIEM_SENTINEL_SHARED_KEY=
SIEM_SENTINEL_LOG_TYPE=AgenticSocEvent
SIEM_SENTINEL_TIMEOUT=10
SIEM_SENTINEL_RETRIES=3
SIEM_SENTINEL_TLS_VERIFY=1
SIEM_SENTINEL_CA_BUNDLE=

# --- Syslog (QRadar / ArcSight / generic syslog receivers) ---
SIEM_SYSLOG_ENABLED=0
# Examples: udp://qradar.local:514  or  tcp://arcsight.local:514
SIEM_SYSLOG_DEST=
# cef | json
SIEM_SYSLOG_FORMAT=cef
SIEM_SYSLOG_FACILITY=1
SIEM_SYSLOG_SEVERITY=5
SIEM_SYSLOG_APP=agentic-soc

# ============================================================================
# Distillation (optional; offline corpora)
# ============================================================================

# Paths inside the distiller container (typically on the same volume as audit ledger).
LEDGER_DIR=/app/ledger
CORPUS_DIR=/app/corpus

# ============================================================================
# Event store (OpenSearch / Elasticsearch compatible) (optional but recommended)
# ============================================================================
# Set to 0 only if you are not running OpenSearch — facets, entity search, and
# Hunts correlation against the index need this enabled (docker-compose defaults to on).

EVENTSTORE_OPENSEARCH_ENABLED=1
EVENTSTORE_OPENSEARCH_URL=http://opensearch:9200
EVENTSTORE_OPENSEARCH_USERNAME=admin
EVENTSTORE_OPENSEARCH_PASSWORD=admin
EVENTSTORE_OPENSEARCH_INDEX=agentic-soc-events
EVENTSTORE_OPENSEARCH_TLS_VERIFY=1

# ============================================================================
# Correlation searches (scheduled rules) (requires OpenSearch)
# ============================================================================

CORRELATION_ENABLED=1
CORRELATION_POLL_SECONDS=15
CORRELATION_MAX_MATCHES=200
# See SOC_DEFAULT_TENANT / SOC_TENANT_ISOLATION / CORRELATION_SOC_TENANT above.

# ============================================================================
# SOAR (very small, approval-gated playbooks; optional)
# ============================================================================

SOAR_ENABLED=0
# Comma-separated allowed webhook base URLs (scheme+host+optional port), e.g.
# "https://hooks.slack.com,https://pagerduty.example.com"
SOAR_WEBHOOK_ALLOWLIST=
SOAR_REQUIRE_APPROVAL=1
